<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".views.ui.HomeFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/logo_netcine"/>

            <TextView
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:text="Só aqui no NetCine você pode descobrir milhões de filmes e series, faça sua busca!"
                android:textColorHint="@color/colorPreto"
                android:textStyle="normal"
                android:textAlignment="center"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="10dp"
                android:textSize="15sp"
                android:layout_gravity="center_horizontal"/>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lançamento"
                android:textSize="17sp"
                android:textColor="@color/colorPreto"
                android:layout_marginTop="5dp"/>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/homeLancamentos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filmes Cinema"
                android:textSize="17sp"
                android:textColor="@color/colorPreto"
                android:layout_marginTop="10dp"/>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/homeFilmesCinema"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Series recentes"
                android:textSize="17sp"
                android:textColor="@color/colorPreto"
                android:layout_marginTop="10dp"/>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/homeSeriesRecentes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>







        </LinearLayout>


    </ScrollView>







</LinearLayout>